# Where rendered beats (.mid, .wav, .mp3, .json) are stored.
# Defaults to <project>/data
VYBRA_DATA_DIR=./data

# Host/port for the API server.
VYBRA_HOST=0.0.0.0
PORT=8000

# URL prefix under which the data directory is mounted.
VYBRA_DATA_URL_PREFIX=/data

# Comma-separated list of allowed CORS origins. Defaults to "*".
# In production, set this to your frontend origin(s).
VYBRA_CORS_ORIGINS=*

# Optional service-wide admin override key. When set, requests carrying
# X-API-Key: <value> bypass per-agent Bearer auth on POST /api/v1/beats.
# Prefer per-agent api keys for normal traffic.
VYBRA_API_KEY=

# Database URL. Defaults to a SQLite file under VYBRA_DATA_DIR.
# Set to a Postgres URL (e.g. on Railway) for production.
# DATABASE_URL=postgresql+psycopg://user:pass@host:5432/vybra_beats

# Secret used to sign human session tokens. MUST be stable across restarts.
# If unset, a random one is generated on boot (tokens won't survive a restart).
AUTH_SECRET=change-me-to-a-long-random-string

# Public URL of this service, used to build claim links.
APP_URL=http://localhost:8000
